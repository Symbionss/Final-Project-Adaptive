{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "SDN Network Monitoring - Traffic & Flow Statistics",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "blue", "value": null },
            { "color": "green", "value": 1 }
          ]},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Active Switches",
      "type": "stat",
      "targets": [{ "expr": "sdn_switch_count", "legendFormat": "Switches", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "blue", "value": null },
            { "color": "orange", "value": 10 }
          ]},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Total Flow Rules",
      "type": "stat",
      "targets": [{ "expr": "sdn_flow_count", "legendFormat": "Flows", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "Bps",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 100000 },
            { "color": "red", "value": 1000000 }
          ]}
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Total TX Rate (All Ports)",
      "type": "stat",
      "targets": [{ "expr": "sum(rate(sdn_port_tx_bytes[1m]))", "legendFormat": "TX Rate", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "Bps",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 100000 },
            { "color": "red", "value": 1000000 }
          ]}
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Total RX Rate (All Ports)",
      "type": "stat",
      "targets": [{ "expr": "sum(rate(sdn_port_rx_bytes[1m]))", "legendFormat": "RX Rate", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": false },
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "id": 5,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "TX Traffic Rate per Port",
      "type": "timeseries",
      "targets": [{ "expr": "rate(sdn_port_tx_bytes{port!=\"4294967294\"}[1m])", "legendFormat": "SW{{dpid}} Port{{port}} TX", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": false },
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "id": 6,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "RX Traffic Rate per Port",
      "type": "timeseries",
      "targets": [{ "expr": "rate(sdn_port_rx_bytes{port!=\"4294967294\"}[1m])", "legendFormat": "SW{{dpid}} Port{{port}} RX", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "unit": "pps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "id": 7,
      "options": { "legend": { "calcs": ["mean"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Packet Rate per Switch (TX)",
      "type": "timeseries",
      "targets": [{ "expr": "sum by (dpid) (rate(sdn_port_tx_packets{port!=\"4294967294\"}[1m]))", "legendFormat": "Switch {{dpid}}", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "lineWidth": 2 },
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]}
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "id": 8,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "TX Errors & RX Dropped per Port",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(sdn_port_tx_errors[1m])", "legendFormat": "SW{{dpid}} P{{port}} TX Err", "refId": "A" },
        { "expr": "rate(sdn_port_rx_dropped[1m])", "legendFormat": "SW{{dpid}} P{{port}} RX Drop", "refId": "B" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 21 },
      "id": 9,
      "options": { "legend": { "calcs": ["mean", "max", "last"], "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "title": "Total Flow Rule Count Over Time",
      "type": "timeseries",
      "targets": [
        { "expr": "sdn_flow_count", "legendFormat": "Total Flows", "refId": "A" },
        { "expr": "sdn_switch_count", "legendFormat": "Active Switches", "refId": "B" }
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "tags": ["sdn", "network", "ryu"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "SDN Network Monitoring",
  "uid": "sdn-network-monitoring",
  "version": 1
}
